-- LÓGICA DE COMANDOS
local function FindPlayer(name)
    name = name:lower()
    for _, p in pairs(Players:GetPlayers()) do
        if p.Name:lower():find(name) or p.DisplayName:lower():find(name) then return p end
    end
end

local function Processar(msg)
    local m = msg:lower()
    if m:sub(1,1) == ":" then m = m:sub(2) end
    local args = m:split(" ")
    local cmd, val = args[1], args[2]
    local char = Player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        if cmd == "to" and val then
            local alvo = FindPlayer(val)
            if alvo and alvo.Character then char.HumanoidRootPart.CFrame = alvo.Character.HumanoidRootPart.CFrame end
        elseif cmd == "speed" then char.Humanoid.WalkSpeed = tonumber(val) or 16
        elseif cmd == "jp" then char.Humanoid.JumpPower = tonumber(val) or 50
        elseif cmd == "nc" then _G.Noclip = not _G.Noclip
        elseif cmd == "esp" then _G.Esp = not _G.Esp
        elseif cmd == "re" then char:BreakJoints()
        elseif cmd == "f" then char.HumanoidRootPart.CFrame = CFrame.new(-943, 98, 2060)
        end
    end
end

CmdInput.FocusLost:Connect(function(enter) if enter then Processar(CmdInput.Text); CmdInput.Text = "" end end)
Player.Chatted:Connect(Processar)


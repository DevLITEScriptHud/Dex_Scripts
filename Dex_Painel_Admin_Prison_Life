-- // ANTI-KICK & ANTI-BAN FUNCTIONAL //
local mt = getrawmetatable(game)
local old = mt.__namecall
setreadonly(mt, false)

mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    -- Bloqueia tentativas do jogo de kickar ou banir por velocidade/teleporte
    if method == "Kick" or method == "kick" then
        return nil
    end
    if self.Name == "MainEvent" or self.Name == "RemoteEvent" then
        if args[1] == "CheckFiend" or args[1] == "Ban" then
            return nil
        end
    end
    return old(self, unpack(args))
end)
setreadonly(mt, true)

